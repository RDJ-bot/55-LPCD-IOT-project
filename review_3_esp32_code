#include <WiFi.h>
#include <Firebase_ESP_Client.h>

// ================= WIFI =================
#define WIFI_SSID "Airtel_jeni_7171"
#define WIFI_PASSWORD "Air@66529"

// ================= FIREBASE =================
#define API_KEY "AIzaSyDBU-ewiaOm-FfeUKjji6djh5UDnCI2xqg"
#define DATABASE_URL "https://review-3-599f7-default-rtdb.asia-southeast1.firebasedatabase.app/"

// ================= PINS =================
#define FLOW1_PIN 25
#define FLOW2_PIN 33
#define RELAY1_PIN 26
#define RELAY2_PIN 27

// ================= VARIABLES =================
volatile int pulse1 = 0;
volatile int pulse2 = 0;

float total1 = 0;
float total2 = 0;

float flowRate1 = 0;
float flowRate2 = 0;

unsigned long lastTime = 0;

float calibrationFactor = 450.0;

// Firebase
FirebaseData fbdo;
FirebaseAuth auth;
FirebaseConfig config;

bool signupOK = false;

// ================= INTERRUPTS =================
void IRAM_ATTR pulseCounter1() {
  pulse1++;
}

void IRAM_ATTR pulseCounter2() {
  pulse2++;
}

// ================= SETUP =================
void setup() {
  Serial.begin(115200);

  pinMode(FLOW1_PIN, INPUT_PULLUP);
  pinMode(FLOW2_PIN, INPUT_PULLUP);

  pinMode(RELAY1_PIN, OUTPUT);
  pinMode(RELAY2_PIN, OUTPUT);

  // 🔥 IMPORTANT: default OPEN (relay OFF)
  digitalWrite(RELAY1_PIN, HIGH);
  digitalWrite(RELAY2_PIN, HIGH);

  attachInterrupt(digitalPinToInterrupt(FLOW1_PIN), pulseCounter1, FALLING);
  attachInterrupt(digitalPinToInterrupt(FLOW2_PIN), pulseCounter2, FALLING);

  // WiFi
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  Serial.print("Connecting WiFi");

  while (WiFi.status() != WL_CONNECTED) {
    Serial.print(".");
    delay(500);
  }

  Serial.println("\nWiFi Connected ✅");

  // Firebase
  config.api_key = API_KEY;
  config.database_url = DATABASE_URL;

  if (Firebase.signUp(&config, &auth, "", "")) {
    Serial.println("Firebase Ready ✅");
    signupOK = true;
  } else {
    Serial.printf("Signup error: %s\n", config.signer.signupError.message.c_str());
  }

  Firebase.begin(&config, &auth);
  Firebase.reconnectWiFi(true);

  lastTime = millis();
}

// ================= LOOP =================
void loop() {

  if ((millis() - lastTime) > 1000) {

    // Calculate flow rate (L/min)
    flowRate1 = (pulse1 / calibrationFactor) * 60.0;
    flowRate2 = (pulse2 / calibrationFactor) * 60.0;

    // Total litres
    total1 += (pulse1 / calibrationFactor);
    total2 += (pulse2 / calibrationFactor);

    pulse1 = 0;
    pulse2 = 0;

    lastTime = millis();

    // ================= DEBUG =================
    Serial.print("H1 Total: ");
    Serial.print(total1);
    Serial.print(" | H2 Total: ");
    Serial.println(total2);

    // ================= VALVE CONTROL =================

    // 🔴 HOUSE 1 (2 L LIMIT)
    if (total1 >= 2.0) {
      digitalWrite(RELAY1_PIN, LOW);   // CLOSE valve
      Serial.println("🚫 House 1 Valve CLOSED");
    } else {
      digitalWrite(RELAY1_PIN, HIGH);  // OPEN valve
      Serial.println("✅ House 1 Valve OPEN");
    }

    // 🔴 HOUSE 2 (55 L LIMIT)
    if (total2 >= 55.0) {
      digitalWrite(RELAY2_PIN, LOW);
      Serial.println("🚫 House 2 Valve CLOSED");
    } else {
      digitalWrite(RELAY2_PIN, HIGH);
      Serial.println("✅ House 2 Valve OPEN");
    }

    // ================= FIREBASE =================
    if (Firebase.ready() && signupOK) {

      Firebase.RTDB.setFloat(&fbdo, "sensorData/house1/flow", flowRate1);
      Firebase.RTDB.setFloat(&fbdo, "sensorData/house1/total", total1);
      Firebase.RTDB.setString(&fbdo, "sensorData/house1/valve",
        (total1 >= 2) ? "CLOSED" : "OPEN");

      Firebase.RTDB.setFloat(&fbdo, "sensorData/house2/flow", flowRate2);
      Firebase.RTDB.setFloat(&fbdo, "sensorData/house2/total", total2);
      Firebase.RTDB.setString(&fbdo, "sensorData/house2/valve",
        (total2 >= 55) ? "CLOSED" : "OPEN");

      Serial.println("Firebase Updated ✅");
    }
  }
}
